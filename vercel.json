{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/archive-old-reports",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/generate-newsletter",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/send-newsletter",
      "schedule": "0 9 * * 1"
    }
  ]
}
