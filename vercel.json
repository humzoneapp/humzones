{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/api/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/archive-old-reports",
      "schedule": "0 0 1 * *"
    }
  ],
  "functions": {
    "api/generate-newsletter.js": { "maxDuration": 60 },
    "api/newsletter.js":          { "maxDuration": 60 }
  }
}
